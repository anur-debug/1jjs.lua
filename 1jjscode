local function findMoveSlot(move, fallbackIndex)
	local explicit = tonumber(getAttribute(move, "Key", nil))
	if explicit then
		return explicit
	end

	local nameNumber = tonumber(string.match(move.Name, "(%d+)"))
	if nameNumber then
		return nameNumber
	end

	return fallbackIndex
end

local function buildSnapshot(character, now)
	local humanoid = getHumanoid(character)
	local root = getRoot(character)
	if not humanoid or not root or humanoid.Health <= 0 then
		return nil
	end

	local moveset = character:FindFirstChild("Moveset")
	local characterState = MoveStates[character] or {}
	local validStateEntries = {}
	local moves = {}

	if moveset then
		local children = moveset:GetChildren()
		table.sort(children, function(a, b)
			local aKey = findMoveSlot(a, 1)
			local bKey = findMoveSlot(b, 1)
			if aKey == bKey then
				return a.Name < b.Name
			end
			return aKey < bKey
		end)

		for index, move in ipairs(children) do
			local slot = findMoveSlot(move, index)
			local baseValue = tonumber(move.Value) or 0

			local state = characterState[move] or {
				MaxCooldown = baseValue,
				LastBaseValue = baseValue,
				TimeStarted = 0,
				AttrCache = {},
				ChildCache = {},
			}

			validStateEntries[move] = true

			if baseValue > state.MaxCooldown then
				state.MaxCooldown = baseValue
			end

			local remaining = 0
			local cooldown = math.max(state.MaxCooldown, baseValue, 0)

			if baseValue ~= state.LastBaseValue then
				if baseValue > state.LastBaseValue and baseValue > 0 then
					state.MaxCooldown = math.max(state.MaxCooldown, baseValue)
					state.TimeStarted = now
				elseif baseValue < state.LastBaseValue and baseValue > 0 then
					state.TimeStarted = now - math.max(0, state.MaxCooldown - baseValue)
				end
				state.LastBaseValue = baseValue
			end

			for attrName, attrValue in pairs(move:GetAttributes()) do
				local lower = string.lower(attrName)
				local cached = state.AttrCache[attrName]

				if cached ~= attrValue then
					if type(attrValue) == "number" then
						if (string.find(lower, "last") or string.find(lower, "start") or string.find(lower, "tick") or string.find(lower, "use")) and attrValue > 0 then
							state.TimeStarted = now
						elseif (string.find(lower, "cooldown") or string.find(lower, "remain") or string.find(lower, "time")) and attrValue > 0 then
							state.MaxCooldown = math.max(state.MaxCooldown, attrValue)
							remaining = math.max(remaining, attrValue)
							state.TimeStarted = now - math.max(0, state.MaxCooldown - attrValue)
						end
					elseif type(attrValue) == "boolean" then
						if attrValue and (string.find(lower, "cooldown") or string.find(lower, "cd") or string.find(lower, "active") or string.find(lower, "used")) then
							state.TimeStarted = now
						end
					end

					state.AttrCache[attrName] = attrValue
				end

				if type(attrValue) == "number" and (string.find(lower, "cooldown") or string.find(lower, "remain") or string.find(lower, "time")) and attrValue > 0 then
					remaining = math.max(remaining, attrValue)
					state.MaxCooldown = math.max(state.MaxCooldown, attrValue)
				end
			end

			for _, child in ipairs(move:GetChildren()) do
				if child:IsA("NumberValue") or child:IsA("IntValue") then
					local lower = string.lower(child.Name)
					local value = tonumber(child.Value) or 0
					local cached = state.ChildCache[child]

					if cached ~= value then
						if value > 0 and value > (cached or 0) and (string.find(lower, "cooldown") or string.find(lower, "remain") or string.find(lower, "time") or string.find(lower, "tick") or string.find(lower, "cd")) then
							state.TimeStarted = now
						end
						state.ChildCache[child] = value
					end

					if value > 0 and (string.find(lower, "cooldown") or string.find(lower, "remain") or string.find(lower, "time") or string.find(lower, "tick") or string.find(lower, "cd")) then
						remaining = math.max(remaining, value)
						state.MaxCooldown = math.max(state.MaxCooldown, value)
					end
				end
			end

			cooldown = math.max(cooldown, state.MaxCooldown, 0)

			if remaining <= 0 and state.TimeStarted > 0 and cooldown > 0 then
				local elapsed = now - state.TimeStarted
				if elapsed < cooldown then
					remaining = cooldown - elapsed
				else
					state.TimeStarted = 0
				end
			end

			characterState[move] = state

			table.insert(moves, {
				Name = move.Name,
				Slot = slot,
				Cooldown = math.max(cooldown, 1),
				Remaining = math.max(remaining, 0),
			})
		end
	end

	for moveObject in pairs(characterState) do
		if not validStateEntries[moveObject] then
			characterState[moveObject] = nil
		end
	end

	MoveStates[character] = characterState

	return {
		Character = character,
		Label = characterLabel(character),
		Moves = moves,
		RootPosition = root.Position,
	}
end

local function refreshSnapshots(now)
	local valid = {}

	for _, character in ipairs(getCharacters()) do
		local snapshot = buildSnapshot(character, now)
		if snapshot then
			Snapshots[character] = snapshot
			valid[character] = true
		end
	end

	for character in pairs(Snapshots) do
		if not valid[character] then
			Snapshots[character] = nil
			MoveStates[character] = nil
			if ActiveTarget == character then
				ActiveTarget = nil
			end
		end
	end
end

local function getSlotMap(snapshot)
	local slotMap = {}
	local spill = {}

	if not snapshot then
		return slotMap
	end

	for _, move in ipairs(snapshot.Moves) do
		if move.Slot >= 1 and move.Slot <= SETTINGS.RowCount and not slotMap[move.Slot] then
			slotMap[move.Slot] = move
		else
			table.insert(spill, move)
		end
	end

	local spillIndex = 1
	for slot = 1, SETTINGS.RowCount do
		if not slotMap[slot] then
			slotMap[slot] = spill[spillIndex]
			spillIndex += 1
		end
	end

	return slotMap
end

