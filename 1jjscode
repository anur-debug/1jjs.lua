RunService.RenderStepped:Connect(function()
    local now = tick()
    RefreshSnapshots(now)

    if ActiveAttacker then
        local snapshot = Snapshots[ActiveAttacker]
        if snapshot then
            RenderSnapshot(snapshot)
        else
            ActiveAttacker = nil
            RenderSnapshot(nil)
        end
    else
        RenderSnapshot(nil)
    end
end)
