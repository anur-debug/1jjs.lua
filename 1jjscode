local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local CoreGui = game:GetService("CoreGui")

-- Determine where to attach the UI
-- If this is an Exploit (Krampus, Synapse etc.), CoreGui is often used.
-- If this is a normal LocalScript, PlayerGui is preferred.
local localPlayer = Players.LocalPlayer
local guiParent = localPlayer and localPlayer:FindFirstChild("PlayerGui") or CoreGui

if not guiParent then
    warn("Could not find suitable GUI parent. Tracker UI might not be visible.")
end

-- Create the main ScreenGui container
-- ResetOnSpawn prevents the GUI from wiping if the LocalPlayer dies
local mainGui = Instance.new("ScreenGui")
mainGui.Name = "CooldownTracker_GUI"
mainGui.ResetOnSpawn = false
mainGui.IgnoreGuiInset = true
mainGui.Parent = guiParent

local renderConnection -- Will hold the RenderStepped connection

-- Configuration 
local Settings = {
    DrawCooldowns = true,
    CooldownFillColor = Color3.fromRGB(60, 160, 255),
    CooldownBackgroundColor = Color3.fromRGB(15, 20, 30),
    TextColor = Color3.fromRGB(230, 240, 255),
    BoxOutlineColor = Color3.fromRGB(30, 40, 60),
    BarSpacing = 2,
    MaxRenderDistance = 100 -- Only show cooldowns for characters within this distance
}

-- Initialize UI Library
local Library, Notifications, Themes = loadstring(game:HttpGet("https://raw.githubusercontent.com/i77lhm/Libraries/refs/heads/main/Bbot/Library.lua"))()

local Window = Library:Window({name = "Cooldown Tracker"})
