local function GetAttribute(inst, attr, default)
    if not inst then
        return default
    end
    local ok, value = pcall(function()
        return inst:GetAttribute(attr)
    end)
    if ok and value ~= nil then
        return value
    end
    return default
end

local function GetRoot(character)
    return character and character:FindFirstChild("HumanoidRootPart")
end

local function GetHumanoid(character)
    return character and character:FindFirstChildOfClass("Humanoid")
end

local function GetCharacters()
    local list = {}
    local seen = {}

    local folder = workspace:FindFirstChild("Characters")
    if folder then
        for _, obj in ipairs(folder:GetChildren()) do
            if obj:IsA("Model") then
                seen[obj] = true
                table.insert(list, obj)
            end
        end
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        local char = plr.Character
        if char and char:IsA("Model") and not seen[char] then
            seen[char] = true
            table.insert(list, char)
        end
    end

    return list
end

local function CharacterLabel(character)
    local plr = Players:GetPlayerFromCharacter(character)
    return plr and plr.Name or character.Name
end

