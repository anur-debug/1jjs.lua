local function resetMoveState(moveState, valueNow)
    moveState.StartedAt = 0
    moveState.LastValue = valueNow
end

local function evaluateNumericField(fieldName, value, moveState)
    if value == nil or value <= 0 then
        return nil, nil, false
    end

    local remaining = nil
    local maxCooldown = nil
    local triggered = false

    if isStrongRemainingName(fieldName) then
        remaining = value
        maxCooldown = value
    elseif isBaseCooldownName(fieldName) then
        maxCooldown = value
    elseif isWeakTimerName(fieldName) then
        if moveState.MaxCooldown > 0 then
            if value <= moveState.MaxCooldown + 0.25 then
                remaining = value
            else
                maxCooldown = value
            end
        else
            remaining = value
            maxCooldown = value
        end
    elseif isTriggerName(fieldName) then
        triggered = true
    end

    return remaining, maxCooldown, triggered
end

local function updateFromValue(moveInstance, moveState, now)
    local valueNow = clampNumber(moveInstance.Value, 0) or 0
    local valueRemaining = nil
    local started = false

    if moveState.LastValue == nil then
        moveState.LastValue = valueNow
    elseif valueNow ~= moveState.LastValue then
        if valueNow > moveState.LastValue then
            moveState.MaxCooldown = math.max(moveState.MaxCooldown, valueNow)
            moveState.StartedAt = now
            started = true
        elseif valueNow > 0 and moveState.MaxCooldown > 0 and valueNow <= moveState.MaxCooldown + 0.25 then
            valueRemaining = valueNow
            moveState.StartedAt = now - math.max(0, moveState.MaxCooldown - valueNow)
        elseif valueNow <= 0 then
            resetMoveState(moveState, valueNow)
        end

        moveState.LastValue = valueNow
    end

    if valueNow > moveState.MaxCooldown then
        moveState.MaxCooldown = valueNow
    end

    return valueNow, valueRemaining, started
end

local function scanAttributes(moveInstance, moveState, now)
    local remaining = nil
    local maxCooldown = nil
    local triggered = false

    for attrName, rawValue in pairs(moveInstance:GetAttributes()) do
        local numericValue = clampNumber(rawValue, nil)
        local oldValue = moveState.AttrCache[attrName]

        if numericValue ~= nil then
            local fieldRemaining, fieldMax, fieldTriggered = evaluateNumericField(attrName, numericValue, moveState)

            if fieldRemaining and (remaining == nil or fieldRemaining > remaining) then
                remaining = fieldRemaining
            end

            if fieldMax and (maxCooldown == nil or fieldMax > maxCooldown) then
                maxCooldown = fieldMax
            end

            if oldValue ~= rawValue and fieldTriggered then
                triggered = true
                moveState.StartedAt = now
            end
        elseif type(rawValue) == "boolean" then
            if oldValue ~= rawValue and rawValue == true and isBooleanTriggerName(attrName) then
                triggered = true
                moveState.StartedAt = now
            end
        end

        moveState.AttrCache[attrName] = rawValue
    end

    return remaining, maxCooldown, triggered
end

local function scanChildren(moveInstance, moveState, now)
    local remaining = nil
    local maxCooldown = nil
    local triggered = false

    for _, child in ipairs(moveInstance:GetChildren()) do
        local childName = child.Name

        if child:IsA("NumberValue") or child:IsA("IntValue") then
            local numericValue = clampNumber(child.Value, nil)
            if numericValue ~= nil then
                local oldValue = moveState.ChildCache[childName]
                local fieldRemaining, fieldMax, fieldTriggered = evaluateNumericField(childName, numericValue, moveState)

                if fieldRemaining and (remaining == nil or fieldRemaining > remaining) then
                    remaining = fieldRemaining
                end

                if fieldMax and (maxCooldown == nil or fieldMax > maxCooldown) then
                    maxCooldown = fieldMax
                end

                if oldValue ~= numericValue and fieldTriggered then
                    triggered = true
                    moveState.StartedAt = now
                end

                moveState.ChildCache[childName] = numericValue
            end
        elseif child:IsA("BoolValue") then
            local oldValue = moveState.ChildCache[childName]
            if oldValue ~= child.Value and child.Value == true and isBooleanTriggerName(childName) then
                triggered = true
                moveState.StartedAt = now
            end
            moveState.ChildCache[childName] = child.Value
        end
    end

    return remaining, maxCooldown, triggered
end

local function buildMoveEntry(moveInstance, key, moveState, now)
    local _, valueRemaining = updateFromValue(moveInstance, moveState, now)

    local attrRemaining, attrMax = scanAttributes(moveInstance, moveState, now)
    local childRemaining, childMax = scanChildren(moveInstance, moveState, now)

    local remaining = nil

    if attrMax then
        moveState.MaxCooldown = math.max(moveState.MaxCooldown, attrMax)
    end

    if childMax then
        moveState.MaxCooldown = math.max(moveState.MaxCooldown, childMax)
    end

    if attrRemaining ~= nil then
        remaining = attrRemaining
        moveState.MaxCooldown = math.max(moveState.MaxCooldown, attrRemaining)
        moveState.StartedAt = now - math.max(0, moveState.MaxCooldown - attrRemaining)
    elseif childRemaining ~= nil then
        remaining = childRemaining
        moveState.MaxCooldown = math.max(moveState.MaxCooldown, childRemaining)
        moveState.StartedAt = now - math.max(0, moveState.MaxCooldown - childRemaining)
    elseif valueRemaining ~= nil then
        remaining = valueRemaining
    end

    if remaining == nil and moveState.StartedAt > 0 and moveState.MaxCooldown > 0 then
        local elapsed = now - moveState.StartedAt
        if elapsed < moveState.MaxCooldown then
            remaining = moveState.MaxCooldown - elapsed
        else
            moveState.StartedAt = 0
            remaining = 0
        end
    end

    remaining = math.max(0, clampNumber(remaining, 0) or 0)

    if remaining <= 0 then
        return nil
    end

    local cooldown = math.max(moveState.MaxCooldown, remaining, 0.01)

    moveState.Key = key

    return {
        Name = moveInstance.Name,
        Key = key,
        Cooldown = cooldown,
        Remaining = remaining,
    }
end

local function buildSnapshot(character, now)
    local humanoid = getHumanoid(character)
    local root = getRoot(character)

    if not humanoid or not root or humanoid.Health <= 0 then
        return nil
    end

    local moveset = character:FindFirstChild("Moveset")
    local charState = MoveStates[character] or {}
    local activeMoves = {}

    if moveset then
        for idx, moveInstance in ipairs(moveset:GetChildren()) do
            local key = tonumber(getAttribute(moveInstance, "Key", idx)) or idx

            local moveState = charState[moveInstance.Name]
            if not moveState then
                moveState = {
                    MaxCooldown = math.max(clampNumber(moveInstance.Value, 0) or 0, 0),
                    LastValue = nil,
                    StartedAt = 0,
                    Key = key,
                    AttrCache = {},
                    ChildCache = {},
                }
                charState[moveInstance.Name] = moveState
            end

            local entry = buildMoveEntry(moveInstance, key, moveState, now)
            if entry then
                table.insert(activeMoves, entry)
            end
        end

        table.sort(activeMoves, function(a, b)
            if a.Key == b.Key then
                return a.Name < b.Name
            end
            return a.Key < b.Key
        end)
    end

    MoveStates[character] = charState

    return {
        Character = character,
        Label = characterLabel(character),
        RootPosition = root.Position,
        Moves = activeMoves,
    }
end

local function refreshSnapshots(now)
    local valid = {}

    for _, character in ipairs(getCharacters()) do
        local snapshot = buildSnapshot(character, now)
        if snapshot then
            Snapshots[character] = snapshot
            valid[character] = true
        end
    end

    for character in pairs(Snapshots) do
        if not valid[character] then
            Snapshots[character] = nil
            MoveStates[character] = nil
            if LockedTarget == character then
                LockedTarget = nil
            end
        end
    end
end

local function renderSnapshot(snapshot)
    if not snapshot then
        TargetLabel.Text = "Target: -"
        Status.Text = "Look at a player and press Z to target."
        hideRows()
        return
    end

    TargetLabel.Text = "Target: " .. snapshot.Label

    if #snapshot.Moves > 0 then
        Status.Text = "Tracking target cooldowns... Press Z again to clear."
    else
        Status.Text = "Locked on target. No active cooldowns found."
    end

    for i, row in ipairs(Rows) do
        local move = snapshot.Moves[i]

        if move then
            row.Visible = true
            row.Label.Text = move.Name
            row.Time.Text = string.format("%.1f", move.Remaining)

            local ratio = 0
            if move.Cooldown > 0 then
                ratio = math.clamp(move.Remaining / move.Cooldown, 0, 1)
            end

            row.BarBack.Fill.Size = UDim2.new(ratio, 0, 1, 0)
        else
            row.Visible = false
            row.Label.Text = ""
            row.Time.Text = ""
            row.BarBack.Fill.Size = UDim2.new(0, 0, 1, 0)
        end
    end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or input.KeyCode ~= Enum.KeyCode.Z then
        return
    end

    if LockedTarget then
        LockedTarget = nil
        Status.Text = "Target cleared. Look at a player and press Z to target."
        renderSnapshot(nil)
        return
    end

    local target = acquireBestTarget(Snapshots)
    if target then
        LockedTarget = target
        renderSnapshot(Snapshots[target])
    else
        Status.Text = "No target found in front of you."
        renderSnapshot(nil)
    end
end)

