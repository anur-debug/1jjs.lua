-- Cache for GUI base containers for each character
local CharacterGuis = {}

-- Store the state of moves across frames to track cooldowns
local MoveStates = {}

-- Helper to safely get an attribute
local function GetAttribute(instance, attr, default)
    if not instance then return default end
    local val = instance:GetAttribute(attr)
    if val ~= nil then return val end
    return default
end

-- Structure creation for a single move UI
local function CreateMoveUI(characterName, moveIndex)
    local container = Instance.new("Frame")
    container.Name = characterName .. "_Move_" .. moveIndex
    container.BackgroundColor3 = Settings.BoxOutlineColor
    container.BackgroundTransparency = 0.3
    container.BorderSizePixel = 1
    container.BorderColor3 = Settings.BoxOutlineColor
    
    local bg = Instance.new("Frame")
    bg.Name = "Background"
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Settings.CooldownBackgroundColor
    bg.BackgroundTransparency = 0.5
    bg.BorderSizePixel = 0
    bg.Parent = container
    
    -- Fill animates from right to left based on `ware.lua` original sizing logic
    local fill = Instance.new("Frame")
    fill.Name = "Fill"
    fill.AnchorPoint = Vector2.new(1, 0)
    fill.Position = UDim2.new(1, 0, 0, 0)
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Settings.CooldownFillColor
    fill.BorderSizePixel = 0
    fill.Parent = container
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Name = "Label"
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = "Move"
    textLabel.TextColor3 = Settings.TextColor
    textLabel.TextStrokeTransparency = 0.5
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.Code
    textLabel.Parent = container

    container.Parent = mainGui
    return container
end

-- Structure creation for the Ultimate Bar
local function CreateUltUI(characterName)
    local container = Instance.new("Frame")
    container.Name = characterName .. "_Ult"
    container.BackgroundColor3 = Settings.BoxOutlineColor
    container.BackgroundTransparency = 0.3
    container.BorderSizePixel = 1
    container.BorderColor3 = Settings.BoxOutlineColor
    
    local bg = Instance.new("Frame")
    bg.Name = "Background"
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Settings.CooldownBackgroundColor
    bg.BackgroundTransparency = 0.5
    bg.BorderSizePixel = 0
    bg.Parent = container
    
    local fill = Instance.new("Frame")
    fill.Name = "Fill"
    fill.AnchorPoint = Vector2.new(0, 1) -- Bottom up fill
    fill.Position = UDim2.new(0, 0, 1, 0)
    fill.Size = UDim2.new(1, 0, 0, 0)
    fill.BackgroundColor3 = Color3.fromRGB(200, 230, 255) -- Bright whitish-blue
    fill.BorderSizePixel = 0
    fill.Parent = container

    container.Parent = mainGui
    return container
end

-- Render loop
renderConnection = RunService.RenderStepped:Connect(function()
    local currentTime = tick()
    
    -- Target the specific Characters folder natively
    local charactersFolder = workspace:FindFirstChild("Characters")
    local targets = {}
    
    if charactersFolder then
        targets = charactersFolder:GetChildren()
    else
        -- Fallback to all workspace children with humanoids if no Characters folder
        for _, obj in ipairs(workspace:GetChildren()) do
            if obj:FindFirstChild("Humanoid") then
                table.insert(targets, obj)
            end
        end
    end
    
    local activeCharacterNames = {}
    
    for _, character in ipairs(targets) do
        -- Skip invalid models (this captures both Players and Dummys)
        if not character:IsA("Model") or not character:FindFirstChild("HumanoidRootPart") or not character:FindFirstChild("Humanoid") then
            continue
        end
        
        local humanoid = character.Humanoid
        local rootPart = character.HumanoidRootPart
        local charName = character.Name
        
        -- Range Check
        if (Camera.CFrame.Position - rootPart.Position).Magnitude > Settings.MaxRenderDistance then
            continue
        end
        
        -- Disable LocalPlayer tracking
        if localPlayer and character == localPlayer.Character then
            continue
        end
        
        if humanoid.Health <= 0 then
            continue
        end

        local moveset = character:FindFirstChild("Moveset")
        if not moveset or not Settings.DrawCooldowns then
            continue
        end
        
        -- Calculate screen position for the base bounding box
        local rootPos, rootOnScreen = Camera:WorldToViewportPoint(rootPart.Position)
        if not rootOnScreen then
            continue
        end
        
        -- Get character size to estimate ESP dimensions
        -- Use ExtentsSize to properly factor in custom Dummy sizes
        local charSize = character:GetExtentsSize()
        local topPos = Camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, charSize.Y / 2, 0))
        local bottomPos = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, charSize.Y / 2, 0))
        
        local boxHeight = math.abs(topPos.Y - bottomPos.Y)
        local boxWidth = boxHeight * 0.5
        
        -- Base position for Cooldown UI (drawn slightly to the right of Character)
        local startX = rootPos.X + (boxWidth / 2) + 5
        local startY = topPos.Y

        -- Gather player moves
        local moves = {}
        for idx, moveInstance in ipairs(moveset:GetChildren()) do
            local key = GetAttribute(moveInstance, "Key", idx)
            local cooldownDuration = moveInstance.Value or 0
            local lastUseId = GetAttribute(moveInstance, "LastUse", 0)
            
            table.insert(moves, {
                Name = moveInstance.Name,
                Instance = moveInstance,
                Key = key,
                Cooldown = cooldownDuration,
                LastUseRecord = lastUseId
            })
        end
        
        -- Sort moves by Key (matches ordered display in ware.lua)
        table.sort(moves, function(a, b) return a.Key < b.Key end)
        
        local numMoves = #moves
        if numMoves == 0 then continue end
        
        -- Dynamic sizing based on bounding box height
        local moveBoxSize = boxHeight / math.max(numMoves, 1)
        moveBoxSize = math.clamp(moveBoxSize, 12, 35) -- Keep text easily readable

        activeCharacterNames[charName] = true
        
        if not CharacterGuis[charName] then CharacterGuis[charName] = {} end
        local activeMoveIds = {}
        
        for i, move in ipairs(moves) do
            local moveId = charName .. "_Move_" .. i
            activeMoveIds[moveId] = true
            
            local yPos = startY + (i - 1) * (moveBoxSize + Settings.BarSpacing)
            
            -- Cooldown Logic Translation
            local stateKey = charName .. "_" .. move.Name
            local moveState = MoveStates[stateKey] or { LastUse = 0, TimeStarted = 0 }
            
            -- Detect when move is used based on LastUse attribute changing
            if move.LastUseRecord ~= moveState.LastUse then
                moveState.LastUse = move.LastUseRecord
                moveState.TimeStarted = currentTime
            end
            MoveStates[stateKey] = moveState
            
            local timePassed = currentTime - moveState.TimeStarted
            local remainingTime = 0
            
            if moveState.TimeStarted > 0 and timePassed < move.Cooldown then
                remainingTime = move.Cooldown - timePassed
            end

            -- Update or Create GUI
            local ui = CharacterGuis[charName][moveId]
            if not ui then
                ui = CreateMoveUI(charName, i)
                CharacterGuis[charName][moveId] = ui
            end
            
            ui.Visible = true
            ui.Position = UDim2.new(0, startX, 0, yPos)
            ui.Size = UDim2.new(0, moveBoxSize, 0, moveBoxSize)
            
            -- Update UI Cooldown Fill Rectangle
            local fill = ui:FindFirstChild("Fill")
            if fill then
                if remainingTime > 0 then
                    local ratio = math.clamp(remainingTime / move.Cooldown, 0, 1)
                    fill.Visible = true
                    fill.Size = UDim2.new(ratio, 0, 1, 0)
                else
                    fill.Visible = false
                end
            end
            
            -- Set Text and maintain padding for crisp rendering
            local textLabel = ui:FindFirstChild("Label")
            if textLabel then
                textLabel.Text = move.Name
                local padding = math.floor(moveBoxSize * 0.15)
                local uiPadding = textLabel:FindFirstChild("UIPadding") or Instance.new("UIPadding", textLabel)
                uiPadding.PaddingTop = UDim.new(0, padding)
                uiPadding.PaddingBottom = UDim.new(0, padding)
            end
        end
        
        -- Ultimate Bar Logic
        local ultId = charName .. "_Ult"
        activeMoveIds[ultId] = true
        
        local totalHeight = (numMoves * moveBoxSize) + ((numMoves - 1) * Settings.BarSpacing)
        local ultWidth = math.max(moveBoxSize * 0.25, 4)
        local ultX = startX + moveBoxSize + Settings.BarSpacing
        
        local targetPlayer = Players:GetPlayerFromCharacter(character)
        local ultValue = 0
        if targetPlayer then
            ultValue = GetAttribute(targetPlayer, "Ultimate", 0)
        else
            ultValue = GetAttribute(character, "Ultimate", 0)
        end
        local ultRatio = math.clamp(ultValue / 100, 0, 1) -- Assuming 0 to 100
        
        local ultUi = CharacterGuis[charName][ultId]
        if not ultUi then
            ultUi = CreateUltUI(charName)
            CharacterGuis[charName][ultId] = ultUi
        end
        
        ultUi.Visible = true
        ultUi.Position = UDim2.new(0, ultX, 0, startY)
        ultUi.Size = UDim2.new(0, ultWidth, 0, totalHeight)
        
        local ultFill = ultUi:FindFirstChild("Fill")
        if ultFill then
            if ultRatio > 0 then
                ultFill.Visible = true
                -- Lerp for smooth visually appealing UI or direct set
                ultFill.Size = UDim2.new(1, 0, ultRatio, 0)
            else
                ultFill.Visible = false
            end
        end
        
        -- Clean up extra move GUIs for this specific character if moves are removed
        for moveId, ui in pairs(CharacterGuis[charName]) do
            if not activeMoveIds[moveId] then
                ui.Visible = false
                ui:Destroy()
                CharacterGuis[charName][moveId] = nil
            end
        end
    end
    
    -- Clean up character GUIs for characters that are no longer actively drawn
    for charName, charUis in pairs(CharacterGuis) do
        if not activeCharacterNames[charName] then
            for moveId, ui in pairs(charUis) do
                ui:Destroy()
            end
            CharacterGuis[charName] = nil
        end
    end
end)
