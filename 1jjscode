local function getAttribute(inst, attrName, default)
    if not inst then
        return default
    end

    local ok, value = pcall(function()
        return inst:GetAttribute(attrName)
    end)

    if ok and value ~= nil then
        return value
    end

    return default
end

local function getHumanoid(character)
    return character and character:FindFirstChildOfClass("Humanoid")
end

local function getRoot(character)
    return character and character:FindFirstChild("HumanoidRootPart")
end

local function getCharacters()
    local list = {}
    local seen = {}

    local characterFolder = workspace:FindFirstChild("Characters")
    if characterFolder then
        for _, obj in ipairs(characterFolder:GetChildren()) do
            if obj:IsA("Model") then
                seen[obj] = true
                table.insert(list, obj)
            end
        end
    end

    for _, player in ipairs(Players:GetPlayers()) do
        local character = player.Character
        if character and character:IsA("Model") and not seen[character] then
            seen[character] = true
            table.insert(list, character)
        end
    end

    return list
end

local function characterLabel(character)
    local player = Players:GetPlayerFromCharacter(character)
    return player and player.Name or character.Name
end

local function lower(str)
    return string.lower(tostring(str or ""))
end

local function nameHasAny(name, tokens)
    local n = lower(name)
    for _, token in ipairs(tokens) do
        if string.find(n, token, 1, true) then
            return true
        end
    end
    return false
end

local function clampNumber(value, fallback)
    value = tonumber(value)
    if value == nil then
        return fallback
    end
    return value
end

local STRONG_REMAINING_TOKENS = {
    "remain",
    "remaining",
    "timeleft",
    "left",
    "lefttime",
    "cooldownleft",
    "currentcooldown",
    "currentcd",
}

local BASE_COOLDOWN_TOKENS = {
    "cooldown",
    "maxcooldown",
    "basecooldown",
    "basedelay",
    "maxcd",
}

local TRIGGER_TOKENS = {
    "last",
    "lastuse",
    "lastused",
    "start",
    "started",
    "use",
    "used",
    "activated",
    "cast",
    "fired",
}

local BOOLEAN_TRIGGER_TOKENS = {
    "cooldown",
    "cd",
    "active",
    "used",
    "firing",
}

local function isStrongRemainingName(name)
    return nameHasAny(name, STRONG_REMAINING_TOKENS)
end

local function isBaseCooldownName(name)
    local n = lower(name)
    if isStrongRemainingName(n) then
        return false
    end
    return nameHasAny(n, BASE_COOLDOWN_TOKENS)
end

local function isWeakTimerName(name)
    local n = lower(name)
    return n == "time" or n == "tick" or n == "timer"
end

local function isTriggerName(name)
    return nameHasAny(name, TRIGGER_TOKENS)
end

local function isBooleanTriggerName(name)
    return nameHasAny(name, BOOLEAN_TRIGGER_TOKENS)
end

local function acquireBestTarget(snapshotMap)
    local cameraCFrame = Camera.CFrame
    local bestTarget = nil
    local bestDot = Settings.TargetFovDot

    for character in pairs(snapshotMap) do
        if character ~= LocalPlayer.Character then
            local root = getRoot(character)
            if root then
                local offset = root.Position - cameraCFrame.Position
                local distance = offset.Magnitude
                if distance <= Settings.TargetMaxDistance and distance > 0 then
                    local dot = cameraCFrame.LookVector:Dot(offset.Unit)
                    if dot > bestDot then
                        bestDot = dot
                        bestTarget = character
                    end
                end
            end
        end
    end

    return bestTarget
end

