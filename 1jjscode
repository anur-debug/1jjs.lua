local function renderSnapshot(snapshot)
	if not snapshot then
		Status.Text = "LOOK AT A PLAYER AND PRESS Z"
		TargetLabel.Text = "TARGET: NONE"
		InfoAccent.BackgroundColor3 = SETTINGS.Accent
		for i = 1, SETTINGS.RowCount do
			applyNoTargetRow(Rows[i])
		end
		return
	end

	Status.Text = "LIVE COOLDOWN LINK ACTIVE"
	TargetLabel.Text = "TARGET: " .. upper(snapshot.Label)
	InfoAccent.BackgroundColor3 = SETTINGS.Hot

	local slotMap = getSlotMap(snapshot)

	for slot = 1, SETTINGS.RowCount do
		local row = Rows[slot]
		local move = slotMap[slot]

		row.BoxText.Text = tostring(slot)
		row.BoxText.TextColor3 = SETTINGS.Text
		row.BoxStroke.Color = SETTINGS.Line

		if move then
			row.Name.Text = upper(move.Name)
			row.Name.TextColor3 = SETTINGS.Text

			if move.Remaining > 0 then
				local ratio = math.clamp(move.Remaining / math.max(move.Cooldown, 0.001), 0, 1)
				row.Timer.Text = string.format("%.1f", move.Remaining)
				row.Timer.TextColor3 = SETTINGS.Hot
				row.Fill.BackgroundColor3 = SETTINGS.Cooldown
				row.Fill.Size = UDim2.new(ratio, 0, 1, 0)
				row.Stroke.Color = SETTINGS.HotSoft
			else
				row.Timer.Text = "READY"
				row.Timer.TextColor3 = SETTINGS.SubText
				row.Fill.BackgroundColor3 = SETTINGS.Ready
				row.Fill.Size = UDim2.new(1, 0, 1, 0)
				row.Stroke.Color = SETTINGS.AccentSoft
			end
		else
			row.Name.Text = "EMPTY"
			row.Name.TextColor3 = SETTINGS.SubText
			row.Timer.Text = "--"
			row.Timer.TextColor3 = SETTINGS.SubText
			row.Fill.BackgroundColor3 = SETTINGS.AccentSoft
			row.Fill.Size = UDim2.new(0, 0, 1, 0)
			row.Stroke.Color = SETTINGS.Stroke
		end
	end
end

local function findBestTarget()
	if not Camera then
		return nil
	end

	local viewportCenter = Vector2.new(Camera.ViewportSize.X * 0.5, Camera.ViewportSize.Y * 0.5)
	local bestTarget = nil
	local bestScore = nil

	for character, snapshot in pairs(Snapshots) do
		if character ~= LocalPlayer.Character then
			local humanoid = getHumanoid(character)
			local root = getRoot(character)

			if humanoid and root and humanoid.Health > 0 then
				local worldPos, onScreen = Camera:WorldToViewportPoint(root.Position)
				if onScreen and worldPos.Z > 0 then
					local offset = root.Position - Camera.CFrame.Position
					local distance = offset.Magnitude
					if distance <= SETTINGS.TargetMaxDistance then
						local dot = Camera.CFrame.LookVector:Dot(offset.Unit)
						if dot >= SETTINGS.TargetMinDot then
							local screenDist = (Vector2.new(worldPos.X, worldPos.Y) - viewportCenter).Magnitude
							local score = screenDist + (distance * 0.18) - (dot * 100)
							if bestScore == nil or score < bestScore then
								bestScore = score
								bestTarget = character
							end
						end
					end
				end
			end
		end
	end

	return bestTarget
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end

	if not Panel.Visible then
		return
	end

	if input.KeyCode == Enum.KeyCode.Z then
		local bestTarget = findBestTarget()

		if bestTarget then
			if ActiveTarget == bestTarget then
				ActiveTarget = nil
			else
				ActiveTarget = bestTarget
				local snapshot = Snapshots[bestTarget]
				if snapshot then
					playSelectionAnimation(snapshot.Label)
				end
			end
		else
			ActiveTarget = nil
		end
	end
end)

