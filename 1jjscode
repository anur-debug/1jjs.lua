--// =========================
local dragging = false
local dragInput = nil
local dragStart = nil
local startPos = nil

local function syncShadow()
	shadow.Position = panel.Position + UDim2.new(0, 0, 0, 4)
end

local function updateDrag(input)
	local delta = input.Position - dragStart
	panel.Position = UDim2.new(
		startPos.X.Scale,
		startPos.X.Offset + delta.X,
		startPos.Y.Scale,
		startPos.Y.Offset + delta.Y
	)
	syncShadow()
end

topbar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = panel.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

topbar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input == dragInput then
		updateDrag(input)
	end
end)

yellowDot.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
		return
	end

	WindowMinimized = not WindowMinimized

	if WindowMinimized then
		body.Visible = false
		footer.Visible = false
		panel:TweenSize(UDim2.new(0, 420, 0, 42), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.18, true)
		shadow:TweenSize(UDim2.new(0, 436, 0, 58), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.18, true)
	else
		body.Visible = true
		footer.Visible = true
		panel:TweenSize(Settings.PanelSize, Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.18, true)
		shadow:TweenSize(UDim2.new(0, 436, 0, 276), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.18, true)
