RunService.RenderStepped:Connect(function()
    local now = tick()

    refreshSnapshots(now)

    if LockedTarget then
        local snapshot = Snapshots[LockedTarget]
        if snapshot then
            renderSnapshot(snapshot)
        else
            LockedTarget = nil
            renderSnapshot(nil)
        end
    else
        renderSnapshot(nil)
    end
end)
