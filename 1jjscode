--// =========================
--// DRAGGING
--// =========================
local dragging = false
local dragInput = nil
local dragStart = nil
local startPos = nil

local function updateDrag(input)
	local delta = input.Position - dragStart
	panel.Position = UDim2.new(
		startPos.X.Scale,
		startPos.X.Offset + delta.X,
		startPos.Y.Scale,
		startPos.Y.Offset + delta.Y
	)
end

titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = panel.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

titleBar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input == dragInput then
		updateDrag(input)
	end
end)

--// =========================
--// HELPERS
--// =========================
local function getAttribute(instance, attr, default)
	if not instance then
		return default
	end

	local value = instance:GetAttribute(attr)
	if value ~= nil then
		return value
	end

	return default
end

local function getCharacterLabel(character)
	local player = Players:GetPlayerFromCharacter(character)
	if player then
		return player.Name
	end

	return character.Name
end

local function getPlayerFromCharacter(character)
	if not character then
		return nil
	end
	return Players:GetPlayerFromCharacter(character)
end

local function isTrackedCharacter(character)
	local player = getPlayerFromCharacter(character)
	if not player then
		return false
	end

	return Settings.ValidUsers[player.Name] == true
end

local function getTargets()
	local targets = {}
	local seen = {}

	local function addModel(model)
		if not model or not model:IsA("Model") or seen[model] then
			return
		end

		local humanoid = model:FindFirstChildOfClass("Humanoid")
		if not humanoid then
			return
		end

		if not isTrackedCharacter(model) then
			return
		end

		seen[model] = true
		table.insert(targets, model)
	end

	for _, player in ipairs(Players:GetPlayers()) do
		addModel(player.Character)
	end

	return targets
end

local function localPlayerRecentlyUsedMove(currentTime, window)
	local localCharacter = localPlayer and localPlayer.Character
	if not localCharacter then
		return false
	end

	local prefix = localCharacter.Name .. "_"

	for stateKey, moveState in pairs(MoveStates) do
		if string.sub(stateKey, 1, #prefix) == prefix then
			if moveState.TimeStarted > 0 and (currentTime - moveState.TimeStarted) <= window then
				return true
			end
		end
	end

	return false
end

local function bindHumanoid(character)
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid or HumanoidConnections[humanoid] then
		return
	end

	LastHealthByHumanoid[humanoid] = humanoid.Health

	HumanoidConnections[humanoid] = humanoid.HealthChanged:Connect(function(newHealth)
		local oldHealth = LastHealthByHumanoid[humanoid]
		local now = tick()

		if oldHealth ~= nil and newHealth < oldHealth then
			local localCharacter = localPlayer and localPlayer.Character

			if localCharacter then
				if character == localCharacter then
					-- you took damage
					setCombatTarget(character, "You took damage")
				else
					-- only count it if YOU recently used a move
					-- and the damaged character is near you
					if localPlayerRecentlyUsedMove(now, Settings.RecentAttackWindow)
						and isNearLocalPlayer(character, 40) then
						setCombatTarget(character, "You dealt damage")
					end
				end
			end
		end

		LastHealthByHumanoid[humanoid] = newHealth
	end)
end

local function clearPanel()
	statusLabel.Text = "Waiting for combat..."
	statusLabel.TextColor3 = Settings.MutedTextColor
	targetLabel.Text = ""

	for _, row in ipairs(MoveRows) do
		row.Visible = false

		local fill = row:FindFirstChild("Fill")
		local label = row:FindFirstChild("Label")

		if fill then
			fill.Visible = false
			fill.Size = UDim2.new(0, 0, 1, 0)
		end

		if label then
			label.Text = ""
		end
	end
end

local function showMovesForSnapshot(snapshot, remainingActiveTime)
	statusLabel.Text = string.format("%s (%.1fs)", LastCombatReason, math.max(remainingActiveTime, 0))
	statusLabel.TextColor3 = Settings.TextColor
	targetLabel.Text = "Target: " .. snapshot.Label

	local moves = snapshot.Moves or {}

	for i, row in ipairs(MoveRows) do
		local move = moves[i]
		local fill = row:FindFirstChild("Fill")
		local label = row:FindFirstChild("Label")

		if move then
			row.Visible = true

			if label then
				label.Text = move.Name
			end

			if fill then
				if move.RemainingTime > 0 and move.Cooldown > 0 then
					local ratio = math.clamp(move.RemainingTime / move.Cooldown, 0, 1)
					fill.Visible = true
					fill.Size = UDim2.new(ratio, 0, 1, 0)
				else
					fill.Visible = false
					fill.Size = UDim2.new(0, 0, 1, 0)
				end
			end
		else
			row.Visible = false

			if label then
				label.Text = ""
			end

			if fill then
				fill.Visible = false
				fill.Size = UDim2.new(0, 0, 1, 0)
			end
		end
	end
end

local function buildSnapshotForCharacter(character, currentTime)
	local moveset = character:FindFirstChild("Moveset")
	local moves = {}

	if not MoveStates[character] then
		MoveStates[character] = {}
	end

	if moveset then
		for idx, moveInstance in ipairs(moveset:GetChildren()) do
			local key = getAttribute(moveInstance, "Key", idx)
			local cooldownDuration = tonumber(moveInstance.Value) or 0
			local lastUseId = getAttribute(moveInstance, "LastUse", 0)

			local charMoveStates = MoveStates[character]
			local moveState = charMoveStates[moveInstance.Name] or {
				LastUse = 0,
				TimeStarted = 0,
			}

			if lastUseId ~= moveState.LastUse then
				moveState.LastUse = lastUseId
				moveState.TimeStarted = currentTime
			end

			charMoveStates[moveInstance.Name] = moveState

			local timePassed = currentTime - moveState.TimeStarted
			local remainingTime = 0

			if moveState.TimeStarted > 0 and cooldownDuration > 0 and timePassed < cooldownDuration then
				remainingTime = cooldownDuration - timePassed
			end

			table.insert(moves, {
				Name = moveInstance.Name,
				Key = key,
				Cooldown = cooldownDuration,
				RemainingTime = remainingTime,
			})
		end

		table.sort(moves, function(a, b)
			return a.Key < b.Key
		end)
	end

	return {
		Character = character,
		Label = getCharacterLabel(character),
		Moves = moves,
	}
end

local function setCombatTarget(character, reason)
	ActiveTarget = character
	ActiveUntil = tick() + Settings.ActiveDisplaySeconds
	LastCombatReason = reason or "Combat active"
end

local function localPlayerRecentlyUsedMove(currentTime, window)
	local localCharacter = localPlayer and localPlayer.Character
	if not localCharacter then
		return false
	end

	local charMoveStates = MoveStates[localCharacter]
	if not charMoveStates then
		return false
	end

	for _, moveState in pairs(charMoveStates) do
		if moveState.TimeStarted > 0 and (currentTime - moveState.TimeStarted) <= window then
			return true
		end
	end

	return false
end

local function bindHumanoid(character)
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid or HumanoidConnections[humanoid] then
		return
	end

	-- ignore anyone not in the tracked username list
	if not isTrackedCharacter(character) then
		return
	end

	LastHealthByHumanoid[humanoid] = humanoid.Health

	HumanoidConnections[humanoid] = humanoid.HealthChanged:Connect(function(newHealth)
		local oldHealth = LastHealthByHumanoid[humanoid]
		local now = tick()

		if oldHealth ~= nil and newHealth < oldHealth then
			local localCharacter = localPlayer and localPlayer.Character

			if localCharacter then
				if character == localCharacter then
					setCombatTarget(character, "You took damage")
				else
					if localPlayerRecentlyUsedMove(now, Settings.RecentAttackWindow)
						and isNearLocalPlayer(character, 40) then
						setCombatTarget(character, "You dealt damage")
					end
				end
			end
		end

		LastHealthByHumanoid[humanoid] = newHealth
	end)
end

local function cleanupHumanoidConnections(validCharacters)
	for humanoid, connection in pairs(HumanoidConnections) do
		local character = humanoid.Parent

		if not humanoid.Parent or not character or not validCharacters[character] then
			if connection then
				connection:Disconnect()
			end

			HumanoidConnections[humanoid] = nil
			LastHealthByHumanoid[humanoid] = nil
		end
	end
end

clearPanel()

--// =========================
--// MAIN LOOP
--// =========================
RunService.RenderStepped:Connect(function()
	local currentTime = tick()
	local targets = getTargets()
	local validCharacters = {}

	for _, character in ipairs(targets) do
		if not character:IsA("Model") then
			continue
		end

		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if not humanoid or humanoid.Health <= 0 then
			continue
		end

		validCharacters[character] = true
		bindHumanoid(character)
		CharacterSnapshots[character] = buildSnapshotForCharacter(character, currentTime)
	end

	cleanupHumanoidConnections(validCharacters)

	for character in pairs(CharacterSnapshots) do
		if not validCharacters[character] then
			CharacterSnapshots[character] = nil
			MoveStates[character] = nil

			if ActiveTarget == character then
				ActiveTarget = nil
				ActiveUntil = 0
				LastCombatReason = "Waiting for combat..."
			end
		end
	end

	local isActive = ActiveTarget ~= nil and currentTime <= ActiveUntil
	local snapshot = isActive and CharacterSnapshots[ActiveTarget] or nil

	if isActive and snapshot then
		showMovesForSnapshot(snapshot, ActiveUntil - currentTime)
	else
		clearPanel()
	end
end)
