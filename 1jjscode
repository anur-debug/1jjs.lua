local function BuildSnapshot(character, now)
    local humanoid = GetHumanoid(character)
    local root = GetRoot(character)
    if not humanoid or not root or humanoid.Health <= 0 then
        return nil
    end

    local moveset = character:FindFirstChild("Moveset")
    local charState = MoveStates[character] or {}
    local moves = {}

    if moveset then
        for idx, moveInstance in ipairs(moveset:GetChildren()) do
            local key = tonumber(GetAttribute(moveInstance, "Key", idx)) or idx
            local val = tonumber(moveInstance.Value) or 0
            
            local state = charState[moveInstance.Name] or {
    MaxCooldown = val,
    LastVal = val,
    TimeStarted = 0,
    Key = key,
    AttrCache = {}
}

-- Update MaxCooldown if the value is permanently larger
if val > state.MaxCooldown then
    state.MaxCooldown = val
end

local remaining = 0
local cooldown = state.MaxCooldown

-- Only treat Value as a live cooldown if it is actually changing
if val ~= state.LastVal then
    if val < state.LastVal and val > 0 then
        -- Value is ticking down
        state.TimeStarted = now - (state.MaxCooldown - val)
    elseif val > state.LastVal then
        -- Cooldown restarted/refreshed
        state.TimeStarted = now
        state.MaxCooldown = val
        cooldown = val
    end
    state.LastVal = val
end

            -- Method 2: Check for any Attributes dynamically changing (Timestamps, booleans, or explicit remaining times)
            local attrs = moveInstance:GetAttributes()
            for attrName, attrVal in pairs(attrs) do
                local lowerName = attrName:lower()
                local lastAttr = state.AttrCache[attrName]
                
                if lastAttr ~= attrVal then
                    if type(attrVal) == "number" then
                        if lowerName:match("last") or lowerName:match("start") or lowerName:match("tick") or lowerName:match("use") then
                            state.TimeStarted = now
                        elseif lowerName:match("cooldown") or lowerName:match("remain") or lowerName:match("time") then
                            if attrVal > 0 then
                                state.TimeStarted = now - math.max(0, state.MaxCooldown - attrVal)
                            end
                        end
                    elseif type(attrVal) == "boolean" then
                        if attrVal == true and (lowerName:match("cooldown") or lowerName:match("cd") or lowerName:match("active") or lowerName:match("used")) then
                            state.TimeStarted = now
                        end
                    end
                    state.AttrCache[attrName] = attrVal
                end
                
                if type(attrVal) == "number" and (lowerName:match("cooldown") or lowerName:match("remain")) and attrVal > 0 then
                    remaining = attrVal
                    if attrVal > cooldown then cooldown = attrVal; state.MaxCooldown = attrVal end
                end
            end

            -- Method 3: Check for Child Values tracking cooldowns dynamically
            for _, child in ipairs(moveInstance:GetChildren()) do
                if child:IsA("NumberValue") or child:IsA("IntValue") then
                    local childName = child.Name:lower()
                    if childName:match("cooldown") or childName:match("time") or childName:match("remain") or childName:match("tick") then
                        local cVal = child.Value
                        if cVal > 0 then
                            remaining = cVal
                            if cVal > cooldown then cooldown = cVal; state.MaxCooldown = cVal end
                        end
                    end
                end
            end

            -- Calculate local remaining time if a trigger was hit but no explicit remaining variable exists
            if remaining == 0 and state.TimeStarted > 0 and cooldown > 0 then
                local elapsed = now - state.TimeStarted
                if elapsed < cooldown then
                    remaining = cooldown - elapsed
                else
                    state.TimeStarted = 0
                end
            end

            -- Prevent UI errors if a move has no inherent cooldown configuration
            if cooldown <= 0 then cooldown = 1 end

            state.Key = key
            charState[moveInstance.Name] = state

            table.insert(moves, {
                Name = moveInstance.Name,
                Key = key,
                Cooldown = cooldown,
                Remaining = remaining,
            })
        end

        table.sort(moves, function(a, b)
            return a.Key < b.Key
        end)
    end

    MoveStates[character] = charState

    return {
        Character = character,
        Label = CharacterLabel(character),
        RootPosition = root.Position,
        Moves = moves,
    }
end

local function RefreshSnapshots(now)
    local valid = {}

    for _, character in ipairs(GetCharacters()) do
        local snap = BuildSnapshot(character, now)
        if snap then
            Snapshots[character] = snap
            valid[character] = true
        end
    end

    for character in pairs(Snapshots) do
        if not valid[character] then
            Snapshots[character] = nil
            MoveStates[character] = nil
            if ActiveAttacker == character then
                ActiveAttacker = nil
            end
        end
    end
end

local function RenderSnapshot(snapshot)
    if not snapshot then
        Attacker.Text = "Target: -"
        Status.Text = "Look at a player and press Z to target."
        HideRows()
        return
    end

    Attacker.Text = "Target: " .. snapshot.Label
    Status.Text = "Tracking target cooldowns..."

    for i, row in ipairs(Rows) do
        local move = snapshot.Moves[i]
        if move then
            row.Visible = true
            row.Label.Text = move.Name

            if move.Remaining > 0 and move.Cooldown > 0 then
                row.Time.Text = string.format("%.1f", move.Remaining)
                row.BarBack.Fill.Size = UDim2.new(math.clamp(move.Remaining / move.Cooldown, 0, 1), 0, 1, 0)
            else
                row.Time.Text = ""
                row.BarBack.Fill.Size = UDim2.new(0, 0, 1, 0)
            end
        else
            row.Visible = false
            row.Label.Text = ""
            row.Time.Text = ""
            row.BarBack.Fill.Size = UDim2.new(0, 0, 1, 0)
        end
    end
end

local TARGET_MAX_DISTANCE = 200
local TARGET_FOV_DOT = 0.85 -- Controls the crosshair forgiveness. 1 is perfectly centered, 0.85 is a slight cone.

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed or input.KeyCode ~= Enum.KeyCode.Z then
        return
    end

    -- Press Z again to clear the current locked target
    if ActiveAttacker then
        ActiveAttacker = nil
        Status.Text = "Target cleared. Look at a player and press Z to target."
        RenderSnapshot(nil)
        return
    end

    local bestTarget = nil
    local bestDot = TARGET_FOV_DOT
    local camCFrame = Camera.CFrame

    for character, _ in pairs(Snapshots) do
        if character ~= LocalPlayer.Character then
            local root = GetRoot(character)
            if root then
                local dist = (root.Position - camCFrame.Position).Magnitude
                if dist <= TARGET_MAX_DISTANCE then
                    local dir = (root.Position - camCFrame.Position).Unit
                    local dot = camCFrame.LookVector:Dot(dir)

                    if dot > bestDot then
                        bestDot = dot
                        bestTarget = character
                    end
                end
            end
        end
    end

    if bestTarget then
        ActiveAttacker = bestTarget
        Status.Text = "Tracking target cooldowns... Press Z again to clear."
        RenderSnapshot(Snapshots[bestTarget])
    else
        Status.Text = "No target found in front of you."
        RenderSnapshot(nil)
    end
end)

