local dragging = false
local dragInput = nil
local dragStart = nil
local startPos = nil

local function updateDrag(input)
    local delta = input.Position - dragStart
    panel.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

topbar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = panel.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

topbar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        updateDrag(input)
    end
end)

local function getAttribute(instance, attr, default)
    if not instance then
        return default
    end

    local value = instance:GetAttribute(attr)
    if value ~= nil then
        return value
    end

    return default
end

local function getCharacterLabel(character)
    local player = Players:GetPlayerFromCharacter(character)
    if player then
        return player.Name
    end
    return character.Name
end

local function getRootPart(character)
    return character and character:FindFirstChild("HumanoidRootPart")
end

local function getAllCharacters()
    local result = {}
    local seen = {}

    local charactersFolder = workspace:FindFirstChild("Characters")
    if charactersFolder then
        for _, model in ipairs(charactersFolder:GetChildren()) do
            if model:IsA("Model") and not seen[model] then
                seen[model] = true
                table.insert(result, model)
            end
        end
    end

    for _, player in ipairs(Players:GetPlayers()) do
        local character = player.Character
        if character and character:IsA("Model") and not seen[character] then
            seen[character] = true
            table.insert(result, character)
        end
    end

    return result
end

local function clearPanel(message)
    panel.Visible = false
    statusLabel.Text = message or "Waiting to be attacked..."
    attackerLabel.Text = "Attacker: -"

    for _, row in ipairs(MoveRows) do
        row.Visible = false
        row.Label.Text = ""
        row.Time.Text = ""
        row.BarBack.Fill.Size = UDim2.new(0, 0, 1, 0)
    end
end

local function showAttackerSnapshot(snapshot, remainingActiveTime)
    if not snapshot then
        clearPanel()
        return
    end

    panel.Visible = true
    statusLabel.Text = string.format("Recently hit (%.1fs)", math.max(remainingActiveTime, 0))
    attackerLabel.Text = "Attacker: " .. snapshot.Label

    for i, row in ipairs(MoveRows) do
        local move = snapshot.Moves[i]
        if move then
            row.Visible = true
            row.Label.Text = move.Name

            if move.RemainingTime > 0 and move.Cooldown > 0 then
                row.Time.Text = string.format("%.1f", move.RemainingTime)
                row.BarBack.Fill.Size = UDim2.new(math.clamp(move.RemainingTime / move.Cooldown, 0, 1), 0, 1, 0)
            else
                row.Time.Text = ""
                row.BarBack.Fill.Size = UDim2.new(0, 0, 1, 0)
            end
        else
            row.Visible = false
            row.Label.Text = ""
            row.Time.Text = ""
            row.BarBack.Fill.Size = UDim2.new(0, 0, 1, 0)
        end
    end
end

local function buildSnapshotForCharacter(character, now)
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = getRootPart(character)
    if not humanoid or humanoid.Health <= 0 or not rootPart then
        return nil
    end

    local moveset = character:FindFirstChild("Moveset")
    local characterState = MoveStates[character] or {}
    local moves = {}

    if moveset then
        for index, moveInstance in ipairs(moveset:GetChildren()) do
            local key = tonumber(getAttribute(moveInstance, "Key", index)) or index
            local cooldownDuration = tonumber(moveInstance.Value) or 0
            local lastUseId = tonumber(getAttribute(moveInstance, "LastUse", 0)) or 0

            local moveState = characterState[moveInstance.Name] or {
                LastUse = 0,
                TimeStarted = 0,
                Cooldown = cooldownDuration,
                Key = key,
            }

            if lastUseId ~= moveState.LastUse then
                moveState.LastUse = lastUseId
                moveState.TimeStarted = now
            end

            moveState.Cooldown = cooldownDuration
            moveState.Key = key
            characterState[moveInstance.Name] = moveState

            local remainingTime = 0
            if moveState.TimeStarted > 0 and cooldownDuration > 0 then
                local elapsed = now - moveState.TimeStarted
                if elapsed < cooldownDuration then
                    remainingTime = cooldownDuration - elapsed
                end
            end

            table.insert(moves, {
                Name = moveInstance.Name,
                Key = key,
                Cooldown = cooldownDuration,
                RemainingTime = remainingTime,
                TimeStarted = moveState.TimeStarted,
            })
        end

        table.sort(moves, function(a, b)
            return a.Key < b.Key
        end)
    end

    MoveStates[character] = characterState

    return {
        Character = character,
        Label = getCharacterLabel(character),
        Moves = moves,
    }
end

local function refreshSnapshots(now)
    local validCharacters = {}

    for _, character in ipairs(getAllCharacters()) do
        if character:IsA("Model") then
            local snapshot = buildSnapshotForCharacter(character, now)
            if snapshot then
                CharacterSnapshots[character] = snapshot
                validCharacters[character] = true
            end
        end
    end

    for character in pairs(CharacterSnapshots) do
        if not validCharacters[character] then
            CharacterSnapshots[character] = nil
            MoveStates[character] = nil
            if ActiveAttacker == character then
                ActiveAttacker = nil
                ActiveUntil = 0
            end
        end
    end
end

local function getMostRecentMoveTime(character, now)
    local snapshot = CharacterSnapshots[character]
    if not snapshot then
        return 0
    end

    local mostRecent = 0
    for _, move in ipairs(snapshot.Moves) do
        if move.TimeStarted > 0 and (now - move.TimeStarted) <= Settings.RecentAttackWindow then
            if move.TimeStarted > mostRecent then
                mostRecent = move.TimeStarted
            end
        end
    end

    return mostRecent
end

local function findLikelyAttacker(now)
    local localCharacter = localPlayer and localPlayer.Character
    local localRoot = getRootPart(localCharacter)
    if not localCharacter or not localRoot then
        return nil
    end

    local bestCharacter = nil
    local bestScore = nil

    for character, snapshot in pairs(CharacterSnapshots) do
        if character ~= localCharacter then
            local rootPart = getRootPart(character)
            local humanoid = character:FindFirstChildOfClass("Humanoid")

            if rootPart and humanoid and humanoid.Health > 0 then
                local distance = (rootPart.Position - localRoot.Position).Magnitude
                if distance <= Settings.MaxAttackDistance then
                    local recentMoveTime = getMostRecentMoveTime(character, now)
                    if recentMoveTime > 0 then
                        local score = recentMoveTime - (distance * 0.02)
                        if not bestScore or score > bestScore then
                            bestScore = score
                            bestCharacter = character
                        end
                    end
                end
            end
        end
    end

    return bestCharacter
end

local function bindLocalHumanoid(character)
    if LocalHumanoidConnection then
        LocalHumanoidConnection:Disconnect()
        LocalHumanoidConnection = nil
    end

    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        return
    end

    LastLocalHealth = humanoid.Health

    LocalHumanoidConnection = humanoid.HealthChanged:Connect(function(newHealth)
        local oldHealth = LastLocalHealth
        LastLocalHealth = newHealth

        if oldHealth and newHealth < oldHealth then
            local now = tick()
            refreshSnapshots(now)

            local attacker = findLikelyAttacker(now)
            if attacker then
                ActiveAttacker = attacker
                ActiveUntil = now + Settings.ActiveDisplaySeconds
                LastReason = "You were attacked"
            else
                ActiveAttacker = nil
                ActiveUntil = 0
                LastReason = "You took damage, attacker not found"
                clearPanel(LastReason)
            end
        end
    end)
end

if localPlayer.Character then
    bindLocalHumanoid(localPlayer.Character)
end

localPlayer.CharacterAdded:Connect(function(character)
    task.wait(0.1)
    bindLocalHumanoid(character)
end)

clearPanel()

RunService.RenderStepped:Connect(function()
    local now = tick()
    refreshSnapshots(now)

    if ActiveAttacker and now <= ActiveUntil then
        local snapshot = CharacterSnapshots[ActiveAttacker]
        if snapshot then
            showAttackerSnapshot(snapshot, ActiveUntil - now)
        else
            clearPanel()
        end
    else
        ActiveAttacker = nil
        clearPanel()
    end
end)
