local dragging = false
local dragInput, dragStart, startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    Panel.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

Topbar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Panel.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

Topbar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        updateDrag(input)
    end
end)

local MoveStates = {}
local Snapshots = {}
local ActiveAttacker = nil
local ActiveUntil = 0
local LastHealth = nil
local HealthConnection = nil

local function HideRows()
    for _, row in ipairs(Rows) do
        row.Visible = false
        row.Label.Text = ""
        row.Time.Text = ""
        row.BarBack.Fill.Size = UDim2.new(0, 0, 1, 0)
    end
end

local function BuildSnapshot(character, now)
    local humanoid = GetHumanoid(character)
    local root = GetRoot(character)
    if not humanoid or not root or humanoid.Health <= 0 then
        return nil
    end

    local moveset = character:FindFirstChild("Moveset")
    local charState = MoveStates[character] or {}
    local moves = {}
    local lastRecentUse = 0
    local recentUseCount = 0

    if moveset then
        for idx, moveInstance in ipairs(moveset:GetChildren()) do
            local key = tonumber(GetAttribute(moveInstance, "Key", idx)) or idx
            local cooldown = tonumber(moveInstance.Value) or 0
            local lastUse = tonumber(GetAttribute(moveInstance, "LastUse", 0)) or 0

            local state = charState[moveInstance.Name] or {
                LastUse = 0,
                TimeStarted = 0,
                Cooldown = cooldown,
                Key = key,
            }

            if lastUse ~= state.LastUse then
                state.LastUse = lastUse
                state.TimeStarted = now
            end

            state.Cooldown = cooldown
            state.Key = key
            charState[moveInstance.Name] = state

            local remaining = 0
            if state.TimeStarted > 0 and cooldown > 0 then
                local elapsed = now - state.TimeStarted
                if elapsed < cooldown then
                    remaining = cooldown - elapsed
                end
            end

            if state.TimeStarted > 0 and (now - state.TimeStarted) <= Settings.RecentAttackWindow then
                recentUseCount += 1
                if state.TimeStarted > lastRecentUse then
                    lastRecentUse = state.TimeStarted
                end
            end

            table.insert(moves, {
                Name = moveInstance.Name,
                Key = key,
                Cooldown = cooldown,
                Remaining = remaining,
            })
        end

        table.sort(moves, function(a, b)
            return a.Key < b.Key
        end)
    end

    MoveStates[character] = charState

    return {
        Character = character,
        Label = CharacterLabel(character),
        RootPosition = root.Position,
        Moves = moves,
        LastRecentUse = lastRecentUse,
        RecentUseCount = recentUseCount,
    }
end

local function RefreshSnapshots(now)
    local valid = {}

    for _, character in ipairs(GetCharacters()) do
        local snap = BuildSnapshot(character, now)
        if snap then
            Snapshots[character] = snap
            valid[character] = true
        end
    end

    for character in pairs(Snapshots) do
        if not valid[character] then
            Snapshots[character] = nil
            MoveStates[character] = nil
            if ActiveAttacker == character then
                ActiveAttacker = nil
                ActiveUntil = 0
            end
        end
    end
end

local function FindLikelyAttacker(now)
    local myCharacter = LocalPlayer.Character
    local myRoot = GetRoot(myCharacter)
    if not myCharacter or not myRoot then
        return nil, -math.huge
    end

    local bestCharacter = nil
    local bestScore = -math.huge

    for character, snap in pairs(Snapshots) do
        if character ~= myCharacter and snap.LastRecentUse > 0 then
            local dist = (snap.RootPosition - myRoot.Position).Magnitude
            if dist <= Settings.MaxAttackDistance then
                local age = now - snap.LastRecentUse
                local recencyScore = math.max(0, Settings.RecentAttackWindow - age) * 8
                local distancePenalty = dist * 0.18
                local moveCountBonus = (snap.RecentUseCount or 0) * 1.25

                local score = recencyScore + moveCountBonus - distancePenalty

                if score > bestScore then
                    bestScore = score
                    bestCharacter = character
                end
            end
        end
    end

    return bestCharacter, bestScore
end

local function RenderSnapshot(snapshot, secondsLeft)
    if not snapshot then
        Attacker.Text = "Attacker: -"
        Status.Text = "Loaded. Waiting for you to be hit..."
        HideRows()
        return
    end

    Attacker.Text = "Attacker: " .. snapshot.Label
    Status.Text = string.format("Triggered %.1fs ago window active", math.max(secondsLeft, 0))

    for i, row in ipairs(Rows) do
        local move = snapshot.Moves[i]
        if move then
            row.Visible = true
            row.Label.Text = move.Name

            if move.Remaining > 0 and move.Cooldown > 0 then
                row.Time.Text = string.format("%.1f", move.Remaining)
                row.BarBack.Fill.Size = UDim2.new(math.clamp(move.Remaining / move.Cooldown, 0, 1), 0, 1, 0)
            else
                row.Time.Text = ""
                row.BarBack.Fill.Size = UDim2.new(0, 0, 1, 0)
            end
        else
            row.Visible = false
            row.Label.Text = ""
            row.Time.Text = ""
            row.BarBack.Fill.Size = UDim2.new(0, 0, 1, 0)
        end
    end
end

local function BindCharacter(character)
    if HealthConnection then
        HealthConnection:Disconnect()
        HealthConnection = nil
    end

    local humanoid = character and character:WaitForChild("Humanoid", 5)
    if not humanoid then
        Status.Text = "Loaded, but no humanoid found"
        return
    end

    LastHealth = humanoid.Health
    Victim.Text = "Victim: " .. LocalPlayer.Name
    Status.Text = "Loaded. Waiting for you to be hit..."

    HealthConnection = humanoid.HealthChanged:Connect(function(newHealth)
    local oldHealth = LastHealth
    LastHealth = newHealth

    if oldHealth and newHealth < oldHealth then
        local now = tick()

        PendingHit = true
        PendingHitUntil = now + Settings.HitResolveWindow
        PendingBestAttacker = nil
        PendingBestScore = -math.huge

        Status.Text = "You were hit. Resolving attacker..."
    end
end)

if LocalPlayer.Character then
    BindCharacter(LocalPlayer.Character)
end

LocalPlayer.CharacterAdded:Connect(function(character)
    task.wait(0.15)
    BindCharacter(character)
end)

HideRows()
print("[CooldownTracker] loaded")

RunService.RenderStepped:Connect(function()
    local now = tick()
    RefreshSnapshots(now)

    if PendingHit then
        if now <= PendingHitUntil then
            local attacker, score = FindLikelyAttacker(now)
            if attacker and score > PendingBestScore then
                PendingBestAttacker = attacker
                PendingBestScore = score
            end
        else
            PendingHit = false

            if PendingBestAttacker then
                ActiveAttacker = PendingBestAttacker
                ActiveUntil = now + Settings.ActiveSeconds
                Attacker.Text = "Attacker: " .. CharacterLabel(PendingBestAttacker)
                Status.Text = "You were hit. Tracking attacker cooldowns..."
            else
                ActiveAttacker = nil
                ActiveUntil = 0
                Attacker.Text = "Attacker: ?"
                Status.Text = "You were hit, but attacker was not found"
                HideRows()
            end
        end
    end

    if ActiveAttacker and now <= ActiveUntil then
        local snapshot = Snapshots[ActiveAttacker]
        if snapshot then
            RenderSnapshot(snapshot, ActiveUntil - now)
        else
            ActiveAttacker = nil
            ActiveUntil = 0
            RenderSnapshot(nil, 0)
        end
    elseif not PendingHit then
        if ActiveAttacker then
            ActiveAttacker = nil
            ActiveUntil = 0
        end
        RenderSnapshot(nil, 0)
    end
end)
